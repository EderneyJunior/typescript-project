{
  "name": "typescript-project",
  "version": "1.0.0",
  "type": "module",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx --env-file=.env src/index.ts",
    "start": "node --env-file=.env .",
    "watch": "tsx --env-file=.env --watch src/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EderneyJunior/typescript-project.git"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/cors": "^11.2.0",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "consola": "^3.4.2",
    "fastify": "^5.8.4",
    "quick.db": "^9.1.7",
    "zod": "^4.3.6"
  },
  "imports": {
    "#settings/*": [
      "./build/settings/*"
    ],
    "#functions/*": [
      "./build/functions/*"
    ],
    "#database/*": [
      "./build/database/index.js"
    ],
    "#schemas/*": [
      "./build/schemas/*"
    ],
    "#services/*": [
      "./build/services/*"
    ],
    "#controllers/*": [
      "./build/controllers/*"
    ]
  }
}
